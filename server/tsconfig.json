{
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "./src",
		"target": "ES2018",
		"lib": ["ES6"],
		"module": "NodeNext",
		"esModuleInterop": true,
		"allowJs": true,
		"resolveJsonModule": true,
		"forceConsistentCasingInFileNames": true,
		"noImplicitAny": true,
		"strict": true,
		"sourceMap": true,
		"skipLibCheck": true,
		"paths": {
			"@/*": ["./src/*"],
			"~/*": ["./*"]
		}
	},
	"exclude": ["./node_modules"],
	"include": ["./**/*.ts"],
	"lib": ["esnext"],
	"ts-node": {
		"esm": true
	}
}
